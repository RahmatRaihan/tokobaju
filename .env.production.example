# =====================================================================
# INSKYLXSTR — Production environment template
# Copy to `.env` on the server and fill in the real values.
# Generate APP_KEY with:  php artisan key:generate
# =====================================================================

APP_NAME=INSKYLXSTR
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.inskylxstr.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logs: keep errors, drop debug noise in production.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (MySQL on the VPS) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inskylxstr
DB_USERNAME=inskylxstr
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Sessions ---
# `database` is safe with multiple Octane workers. SECURE_COOKIE must be true on HTTPS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.inskylxstr.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Cache: `database` needs no extra service. Use `redis` if you install Redis.
CACHE_STORE=database

# --- Mail (SMTP) — fill with your provider (Mailgun, Brevo, Gmail, Zoho, etc.) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@inskylxstr.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- First admin account (used by AdminUserSeeder) ---
# Set these BEFORE running `php artisan db:seed`. If ADMIN_PASSWORD is left
# blank in production, a strong random one is generated and printed once.
ADMIN_NAME="Store Admin"
ADMIN_EMAIL=admin@inskylxstr.com
ADMIN_PASSWORD=
ADMIN_PHONE=6281234567890

# --- Octane (FrankenPHP) ---
OCTANE_SERVER=frankenphp

# Vite build-time app name (baked into the frontend at `npm run build`).
VITE_APP_NAME="${APP_NAME}"
